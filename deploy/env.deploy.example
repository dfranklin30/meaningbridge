# ============================================================
# MeaningBridge — Google Cloud deployment settings
# Copy this file to env.deploy and fill in each value.
# ============================================================

GCP_PROJECT_ID=humanity-plus-ai
GCP_REGION=us-east1

# --- Database (Neon) ---
# Connection string for the NEW meaningbridge database in Neon
DATABASE_URL=

# --- Public origin (used in emailed links) ---
# Set to the custom domain once one is mapped; the .run.app URL until then
APP_ORIGIN=

# --- AI (Google Gemini free tier drives ALL providers) ---
# Same key for all three integration slots; base URLs point at Gemini's
# OpenAI-compatible endpoint.
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
AI_INTEGRATIONS_OPENROUTER_API_KEY=
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_CHAT_MODEL=gemini-2.5-flash
AI_IMAGE_MODEL=gemini-2.5-flash-image

# --- Auth (Clerk — same values as Replit Secrets) ---
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Encrypted health data (MUST match Replit exactly) ---
PHI_ENCRYPTION_KEY=

# --- Clinician platform integration (copy from Replit if set) ---
HEALTHIE_API_KEY=
HEALTHIE_API_URL=

# --- Photo storage (Google Cloud Storage bucket paths) ---
PUBLIC_OBJECT_SEARCH_PATHS=/humanity-plus-ai-meaningbridge/public
PRIVATE_OBJECT_DIR=/humanity-plus-ai-meaningbridge/private
